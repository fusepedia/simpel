    'Penggunaan Optical Power Meter (OPM)',
    'Penggunaan Visual Fault Locator (VFL)',
    'Penggunaan OTDR untuk pengukuran',
    'Membaca dan menganalisa trace OTDR',
    'Pengukuran insertion loss dan return loss',
    'Standar pengukuran jaringan FO',
    'Dokumentasi hasil pengukuran'
  ]},
  { modul:7, judul:'Instalasi Jaringan FTTH Indoor & Outdoor', jp:40, materi:[
    'Penarikan kabel fiber optik aerial',
    'Penarikan kabel fiber optik underground',
    'Instalasi ODP dan pendistribusian kabel',
    'Instalasi kabel drop ke pelanggan',
    'Instalasi roset optik indoor',
    'Konfigurasi ONU/ONT pelanggan',
    'Setting layanan internet pada ONU/ONT',
    'Praktek instalasi lengkap FTTH'
  ]},
  { modul:8, judul:'Troubleshooting Jaringan Fiber Optik', jp:24, materi:[
    'Identifikasi gangguan jaringan FO',
    'Troubleshooting menggunakan OPM dan VFL',
    'Troubleshooting menggunakan OTDR',
    'Perbaikan kabel putus di lapangan',
    'Analisa dan perbaikan redaman tinggi',
    'Dokumentasi troubleshooting dan pelaporan'
  ]},
  { modul:9, judul:'Evaluasi dan Uji Kompetensi', jp:16, materi:[
    'Ujian teori komunikasi serat optik',
    'Ujian praktik splicing',
    'Ujian praktik terminasi',
    'Ujian praktik pengukuran OTDR',
    'Ujian praktik instalasi FTTH',
    'Penilaian sikap kerja dan K3',
    'Penerbitan sertifikat kompetensi'
  ]}
];

// Peminjaman records
let dataPeminjaman = [];
let currentPeminjamanId = null;

// ============================================================
// INITIALIZATION
// ============================================================
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('preloader').classList.add('hidden');
  }, 1200);

  renderPeralatan();
  renderBahan();
  renderKurikulum();
  animateCounters();
  setDefaultDates();
  updateBadges();
});

// ============================================================
// NAVIGATION
// ============================================================
function navigateTo(page) {
  // Hide all pages
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));

  // Show target page
  const targetPage = document.getElementById('page-' + page);
  if (targetPage) targetPage.classList.add('active');

  // Activate nav item
  const navItem = document.querySelector(`.nav-item[data-page="${page}"]`);
  if (navItem) navItem.classList.add('active');

  // Update topbar
  const titles = {
    dashboard: ['Dashboard', 'Ringkasan data dan aktivitas sistem'],
    peralatan: ['Inventaris Peralatan', 'Kelola data peralatan pelatihan'],
    bahan: ['Bahan Pelatihan', 'Data stok bahan habis pakai'],
    peminjaman: ['Peminjaman Baru', 'Ajukan peminjaman peralatan & bahan'],
    riwayat: ['Riwayat Peminjaman', 'Daftar semua transaksi peminjaman'],
    kurikulum: ['Kurikulum', 'Kurikulum pelatihan sesuai program Kemnaker'],
    tentang: ['Tentang Kami', 'Tim Instruktur & Pengembang'],
    preview: ['Preview Dokumen', 'Preview dokumen peminjaman']
  };
  const t = titles[page] || ['', ''];
  document.getElementById('topbar-title').textContent = t[0];
  document.getElementById('topbar-subtitle').textContent = t[1];

  // Close sidebar on mobile
  document.getElementById('sidebar').classList.remove('open');

  // Scroll to top
  window.scrollTo(0, 0);
}

function toggleSidebar() {
  document.getElementById('sidebar').classList.toggle('open');
}

// ============================================================
// RENDER PERALATAN
// ============================================================
let filterPeralatanKat = 'all';
let searchPeralatanQuery = '';

function renderPeralatan() {
  const grid = document.getElementById('peralatanGrid');
  let filtered = dataPeralatan.filter(item => {
    const matchKat = filterPeralatanKat === 'all' || item.kategori === filterPeralatanKat;
    const matchSearch = item.nama.toLowerCase().includes(searchPeralatanQuery.toLowerCase()) ||
                       item.kode.toLowerCase().includes(searchPeralatanQuery.toLowerCase());
    return matchKat && matchSearch;
  });

  if (filtered.length === 0) {
    grid.innerHTML = '<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--text-muted)"><i class="fas fa-search" style="font-size:36px;display:block;margin-bottom:12px"></i>Tidak ada peralatan ditemukan</div>';
    return;
  }

  grid.innerHTML = filtered.map(item => {
    const pct = Math.round((item.tersedia / item.jumlah) * 100);
    const barClass = pct > 70 ? 'high' : pct > 30 ? 'mid' : 'low';
    const katLabel = item.kategori === 'hp' ? '📱 Teknisi HP' : '🔌 Fiber Optik';
    return `
      <div class="item-card">
        <div style="display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px">
          <div class="item-icon" style="background:${item.kategori==='hp'?'rgba(245,158,11,0.1)':'rgba(6,182,212,0.1)'};font-size:28px">
            ${item.icon}
          </div>
          <span class="badge ${item.tersedia>0?'badge-success':'badge-danger'}">${item.tersedia>0?'Tersedia':'Habis'}</span>
        </div>
        <h4>${item.nama}</h4>
        <div class="item-code">${item.kode} • ${katLabel}</div>
        <div class="item-meta">
          <div class="item-meta-row"><span>Total Unit</span><span>${item.jumlah}</span></div>
          <div class="item-meta-row"><span>Tersedia</span><span style="color:var(--success);font-weight:700">${item.tersedia}</span></div>
          <div class="item-meta-row"><span>Dipinjam</span><span style="color:var(--warning)">${item.jumlah - item.tersedia}</span></div>
          <div class="item-meta-row"><span>Kondisi</span><span>${item.kondisi}</span></div>
        </div>
        <div class="stock-bar">
          <div class="stock-bar-fill ${barClass}" style="width:${pct}%"></div>
        </div>
      </div>
    `;
  }).join('');
}

function filterPeralatan(kat) {
  filterPeralatanKat = kat;
  document.querySelectorAll('#tabsPeralatan .tab-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  renderPeralatan();
}

function searchPeralatan(q) {
  searchPeralatanQuery = q;
  renderPeralatan();
}

// ============================================================
// RENDER BAHAN
// ============================================================
let filterBahanKat = 'all';
let searchBahanQuery = '';

function renderBahan() {
  const tbody = document.getElementById('bahanTbody');
  let filtered = dataBahan.filter(item => {
    const matchKat = filterBahanKat === 'all' || item.kategori === filterBahanKat;
    const matchSearch = item.nama.toLowerCase().includes(searchBahanQuery.toLowerCase()) ||
                       item.kode.toLowerCase().includes(searchBahanQuery.toLowerCase());
    return matchKat && matchSearch;
  });

  if (filtered.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8" style="text-align:center;padding:40px;color:var(--text-muted)">Tidak ada bahan ditemukan</td></tr>';
    return;
  }

  tbody.innerHTML = filtered.map((item, idx) => {
    const sisa = item.stok - item.terpakai;
    const pct = Math.round((sisa / item.stok) * 100);
    const statusClass = pct > 50 ? 'badge-success' : pct > 20 ? 'badge-warning' : 'badge-danger';
    const statusText = pct > 50 ? 'Aman' : pct > 20 ? 'Menipis' : 'Kritis';
    const katLabel = item.kategori === 'hp' ? '📱 Teknisi HP' : '🔌 Fiber Optik';
    return `
      <tr>
        <td style="font-weight:600">${idx + 1}</td>
        <td><code style="background:var(--bg-card);padding:2px 8px;border-radius:4px;font-size:12px">${item.kode}</code></td>
        <td style="font-weight:600">${item.nama}</td>
        <td>${katLabel}</td>
        <td style="font-weight:700">${sisa} <span style="color:var(--text-muted);font-weight:400">/ ${item.stok}</span></td>
        <td>${item.satuan}</td>
        <td>${item.terpakai}</td>
        <td><span class="badge ${statusClass}">${statusText}</span></td>
      </tr>
    `;
  }).join('');
}

function filterBahan(kat) {
  filterBahanKat = kat;
  document.querySelectorAll('#tabsBahan .tab-btn').forEach(b => b.classList.remove('active'));
  event.target.classList.add('active');
  renderBahan();
}

function searchBahan(q) {
  searchBahanQuery = q;
  renderBahan();
}

// ============================================================
// KURIKULUM
// ============================================================
function renderKurikulum() {
  renderModules('kurikulumHPModules', kurikulumHP);
  renderModules('kurikulumFOModules', kurikulumFO);
}

function renderModules(containerId, data) {
  const container = document.getElementById(containerId);
  container.innerHTML = data.map(m => `
    <div class="curriculum-module">
      <div class="module-header" onclick="toggleModule(this)">
        <div style="display:flex;align-items:center">
          <div class="module-num">${m.modul}</div>
          <div class="module-info">
            <h4>${m.judul}</h4>
            <span>${m.jp} Jam Pelatihan • ${m.materi.length} Materi</span>
          </div>
        </div>
        <i class="fas fa-chevron-down module-toggle"></i>
      </div>
      <div class="module-content">
        <ul>${m.materi.map(mt => `<li>${mt}</li>`).join('')}</ul>
      </div>
    </div>
  `).join('');
}

function toggleModule(header) {
  const content = header.nextElementSibling;
  const toggle = header.querySelector('.module-toggle');
  content.classList.toggle('open');
  toggle.classList.toggle('open');
}

function showKurikulum(type, btn) {
  document.querySelectorAll('.kurikulum-content').forEach(c => c.style.display = 'none');
  document.querySelectorAll('.tabs .tab-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById(type === 'hp' ? 'kurikulumHP' : 'kurikulumFO').style.display = 'block';
}

// ============================================================
// PEMINJAMAN FORM - STEP MANAGEMENT
// ============================================================
let currentStep = 1;

function nextStep(step) {
  // Validate current step
  if (step === 2 && !validateStep1()) return;
  if (step === 3 && !validateStep2()) return;
  if (step === 4) {
    if (!validateStep3()) return;
    generateReview();
  }

  currentStep = step;
  updateStepUI();
}

function prevStep(step) {
  currentStep = step;
  updateStepUI();
}

function updateStepUI() {
  // Hide all step contents
  document.querySelectorAll('.step-content').forEach(s => s.classList.remove('active'));
  document.getElementById('step' + currentStep).classList.add('active');

  // Update step indicators
  document.querySelectorAll('.step').forEach((s, i) => {
    s.classList.remove('active', 'completed');
    if (i + 1 === currentStep) s.classList.add('active');
    if (i + 1 < currentStep) s.classList.add('completed');
  });
}

function validateStep1() {
  const nama = document.getElementById('pNama').value.trim();
  const nomor = document.getElementById('pNomor').value.trim();
  const program = document.getElementById('pProgram').value;
  if (!nama || !nomor || !program) {
    showToast('Harap lengkapi semua field yang bertanda (*)', 'error');
    return false;
  }
  return true;
}

function validateStep2() {
  const selected = getSelectedItems();
  if (selected.peralatan.length === 0 && selected.bahan.length === 0) {
    showToast('Pilih minimal satu item peralatan atau bahan', 'error');
    return false;
  }
  return true;
}

function validateStep3() {
  const tglPinjam = document.getElementById('pTanggalPinjam').value;
  const tglKembali = document.getElementById('pTanggalKembali').value;
  if (!tglPinjam || !tglKembali) {
    showToast('Harap isi tanggal pinjam dan tanggal kembali', 'error');
    return false;
  }
  if (new Date(tglKembali) <= new Date(tglPinjam)) {
    showToast('Tanggal kembali harus setelah tanggal pinjam', 'error');
    return false;
  }
  return true;
}

// ============================================================
// PEMINJAMAN - ITEM SELECTION
// ============================================================
function updateItemList() {
  const program = document.getElementById('pProgram').value;
  renderSelectPeralatan(program);
  renderSelectBahan(program);
}

function renderSelectPeralatan(program) {
  const grid = document.getElementById('selectPeralatanGrid');
  const filtered = program ? dataPeralatan.filter(p => p.kategori === program) : dataPeralatan;
  grid.innerHTML = filtered.map(item => `
    <label class="eq-select-card" onclick="toggleSelect(this)" data-id="p-${item.id}">
      <input type="checkbox" name="peralatan" value="${item.id}">
      <div class="eq-check"><i class="fas fa-check"></i></div>
      <div class="eq-select-info">
        <h5>${item.icon} ${item.nama}</h5>
        <p>${item.kode} • Tersedia: ${item.tersedia}</p>
      </div>
      <input type="number" class="qty-input" value="1" min="1" max="${item.tersedia}" onclick="event.stopPropagation()">
    </label>
  `).join('');
}

function renderSelectBahan(program) {
  const grid = document.getElementById('selectBahanGrid');
  const filtered = program ? dataBahan.filter(b => b.kategori === program) : dataBahan;
  grid.innerHTML = filtered.map(item => {
    const sisa = item.stok - item.terpakai;
    return `
      <label class="eq-select-card" onclick="toggleSelect(this)" data-id="b-${item.id}">
        <input type="checkbox" name="bahan" value="${item.id}">
        <div class="eq-check"><i class="fas fa-check"></i></div>
        <div class="eq-select-info">
          <h5>${item.nama}</h5>
          <p>${item.kode} • Sisa: ${sisa} ${item.satuan}</p>
        </div>
        <input type="number" class="qty-input" value="1" min="1" max="${sisa}" onclick="event.stopPropagation()">
      </label>
    `;
  }).join('');
}

function toggleSelect(card) {
  const checkbox = card.querySelector('input[type="checkbox"]');
  checkbox.checked = !checkbox.checked;
  card.classList.toggle('selected', checkbox.checked);
}

function getSelectedItems() {
  const peralatan = [];
  const bahan = [];

  document.querySelectorAll('#selectPeralatanGrid .eq-select-card.selected').forEach(card => {
    const id = parseInt(card.querySelector('input[type="checkbox"]').value);
    const qty = parseInt(card.querySelector('.qty-input').value) || 1;
    const item = dataPeralatan.find(p => p.id === id);
    if (item) peralatan.push({ ...item, qty });
  });

  document.querySelectorAll('#selectBahanGrid .eq-select-card.selected').forEach(card => {
    const id = parseInt(card.querySelector('input[type="checkbox"]').value);
    const qty = parseInt(card.querySelector('.qty-input').value) || 1;
    const item = dataBahan.find(b => b.id === id);
    if (item) bahan.push({ ...item, qty });
  });

  return { peralatan, bahan };
}

// ============================================================
// REVIEW & CONFIRM
// ============================================================
function generateReview() {
  const selected = getSelectedItems();
  const programName = document.getElementById('pProgram').value === 'hp' ?
    'Teknisi Telepon Seluler' : 'Instalasi Fiber Optik';

  let html = `
    <div class="card" style="margin-bottom:16px;background:rgba(99,102,241,0.05)">
      <h4 style="font-size:15px;margin-bottom:16px;color:var(--primary-light)">
        <i class="fas fa-user"></i> Data Peminjam
      </h4>
      <div class="grid-2" style="gap:12px">
        <div class="item-meta-row"><span style="color:var(--text-muted)">Nama</span>
          <span style="font-weight:600">${document.getElementById('pNama').value}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">No. Peserta</span>
          <span style="font-weight:600">${document.getElementById('pNomor').value}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">Program</span>
          <span style="font-weight:600">${programName}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">Angkatan</span>
          <span style="font-weight:600">${document.getElementById('pAngkatan').value || '-'}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">Tgl Pinjam</span>
          <span style="font-weight:600">${formatDate(document.getElementById('pTanggalPinjam').value)}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">Tgl Kembali</span>
          <span style="font-weight:600">${formatDate(document.getElementById('pTanggalKembali').value)}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">Instruktur</span>
          <span style="font-weight:600">${document.getElementById('pInstruktur').value}</span></div>
        <div class="item-meta-row"><span style="color:var(--text-muted)">Lokasi</span>
          <span style="font-weight:600">${document.getElementById('pLokasi').value}</span></div>
      </div>
    </div>`;

  if (selected.peralatan.length > 0) {
    html += `<div class="card" style="margin-bottom:16px">
      <h4 style="font-size:15px;margin-bottom:12px;color:var(--primary-light)">
        <i class="fas fa-tools"></i> Peralatan yang Dipinjam
      </h4>
      <div class="table-wrapper"><table class="table">
        <thead><tr><th>No</th><th>Kode</th><th>Nama Peralatan</th><th>Jumlah</th></tr></thead>
        <tbody>${selected.peralatan.map((p, i) =>
          `<tr><td>${i+1}</td><td><code>${p.kode}</code></td><td>${p.nama}</td><td style="font-weight:700">${p.qty} unit</td></tr>`
        ).join('')}</tbody>
      </table></div>
    </div>`;
  }

  if (selected.bahan.length > 0) {
    html += `<div class="card" style="margin-bottom:16px">
      <h4 style="font-size:15px;margin-bottom:12px;color:var(--accent)">
        <i class="fas fa-box-open"></i> Bahan yang Digunakan
      </h4>
      <div class="table-wrapper"><table class="table">
        <thead><tr><th>No</th><th>Kode</th><th>Nama Bahan</th><th>Jumlah</th><th>Satuan</th></tr></thead>
        <tbody>${selected.bahan.map((b, i) =>
          `<tr><td>${i+1}</td><td><code>${b.kode}</code></td><td>${b.nama}</td><td style="font-weight:700">${b.qty}</td><td>${b.satuan}</td></tr>`
        ).join('')}</tbody>
      </table></div>
    </div>`;
  }

  document.getElementById('reviewContent').innerHTML = html;
}

// ============================================================
// SUBMIT PEMINJAMAN
// ============================================================
function submitPeminjaman() {
  const selected = getSelectedItems();
  const programVal = document.getElementById('pProgram').value;
  const programName = programVal === 'hp' ? 'Teknisi Telepon Seluler' : 'Instalasi Fiber Optik';

  const record = {
    id: 'TRX-' + new Date().getFullYear() + '-' + String(dataPeminjaman.length + 1).padStart(4, '0'),
    nama: document.getElementById('pNama').value,
    nomor: document.getElementById('pNomor').value,
    program: programName,
    programKode: programVal,
    angkatan: document.getElementById('pAngkatan').value || '-',
    keperluan: document.getElementById('pKeperluan').value || '-',
    tglPinjam: document.getElementById('pTanggalPinjam').value,
    tglKembali: document.getElementById('pTanggalKembali').value,
    instruktur: document.getElementById('pInstruktur').value,
    lokasi: document.getElementById('pLokasi').value,
    catatan: document.getElementById('pCatatan').value || '-',
    peralatan: selected.peralatan,
    bahan: selected.bahan,
    status: 'Aktif',
    createdAt: new Date().toISOString()
  };

  dataPeminjaman.push(record);
  updateBadges();
  renderRiwayat();

  // Add activity
  addActivity(`Peminjaman baru oleh ${record.nama}`, `${record.id} - ${record.program}`, 'green');

  showToast('Peminjaman berhasil disimpan! ID: ' + record.id, 'success');

  // Reset form
  resetForm();

  // Navigate to riwayat
  setTimeout(() => navigateTo('riwayat'), 500);
}

function resetForm() {
  document.getElementById('pNama').value = '';
  document.getElementById('pNomor').value = '';
  document.getElementById('pProgram').value = '';
  document.getElementById('pAngkatan').value = '';
  document.getElementById('pKeperluan').value = '';
  document.getElementById('pCatatan').value = '';
  document.getElementById('selectPeralatanGrid').innerHTML = '';
  document.getElementById('selectBahanGrid').innerHTML = '';
  currentStep = 1;
  updateStepUI();
  setDefaultDates();
}

// ============================================================
// RIWAYAT
// ============================================================
function renderRiwayat() {
  const tbody = document.getElementById('riwayatTbody');
  if (dataPeminjaman.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">
      <i class="fas fa-inbox" style="font-size:36px;display:block;margin-bottom:12px"></i>
      Belum ada data peminjaman. Silakan buat peminjaman baru.
    </td></tr>`;
    return;
  }

  tbody.innerHTML = dataPeminjaman.map(r => {
    const statusClass = r.status === 'Aktif' ? 'badge-info' :
                       r.status === 'Dikembalikan' ? 'badge-success' : 'badge-warning';
    return `
      <tr>
        <td><code style="background:var(--bg-card);padding:2px 8px;border-radius:4px;font-size:12px;font-weight:700">${r.id}</code></td>
        <td style="font-weight:600">${r.nama}</td>
        <td>${r.program}</td>
        <td>${formatDate(r.tglPinjam)}</td>
        <td>${formatDate(r.tglKembali)}</td>
        <td><span class="badge ${statusClass}">${r.status}</span></td>
        <td>
          <div style="display:flex;gap:6px">
            <button class="btn btn-sm btn-primary" onclick="previewPeminjaman('${r.id}')" title="Preview">
              <i class="fas fa-eye"></i>
            </button>
            <button class="btn btn-sm btn-success" onclick="returnPeminjaman('${r.id}')" title="Kembalikan">
              <i class="fas fa-undo"></i>
            </button>
          </div>
        </td>
      </tr>
    `;
  }).join('');
}

function searchRiwayat(q) {
  // Simple search - re-render with filter
  const tbody = document.getElementById('riwayatTbody');
  const filtered = dataPeminjaman.filter(r =>
    r.id.toLowerCase().includes(q.toLowerCase()) ||
    r.nama.toLowerCase().includes(q.toLowerCase()) ||
    r.program.toLowerCase().includes(q.toLowerCase())
  );

  if (filtered.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:40px;color:var(--text-muted)">Tidak ditemukan</td></tr>`;
    return;
  }

  tbody.innerHTML = filtered.map(r => {
    const statusClass = r.status === 'Aktif' ? 'badge-info' :
                       r.status === 'Dikembalikan' ? 'badge-success' : 'badge-warning';
    return `
      <tr>
        <td><code style="background:var(--bg-card);padding:2px 8px;border-radius:4px;font-size:12px;font-weight:700">${r.id}</code></td>
        <td style="font-weight:600">${r.nama}</td>
        <td>${r.program}</td>
        <td>${formatDate(r.tglPinjam)}</td>
        <td>${formatDate(r.tglKembali)}</td>
        <td><span class="badge ${statusClass}">${r.status}</span></td>
        <td>
          <div style="display:flex;gap:6px">
            <button class="btn btn-sm btn-primary" onclick="previewPeminjaman('${r.id}')"><i class="fas fa-eye"></i></button>
            <button class="btn btn-sm btn-success" onclick="returnPeminjaman('${r.id}')"><i class="fas fa-undo"></i></button>
          </div>
        </td>
      </tr>
    `;
  }).join('');
}

function returnPeminjaman(id) {
  const record = dataPeminjaman.find(r => r.id === id);
  if (record) {
    record.status = 'Dikembalikan';
    renderRiwayat();
    updateBadges();
    addActivity(`Peralatan dikembalikan oleh ${record.nama}`, record.id, 'blue');
    showToast('Peralatan berhasil dikembalikan!', 'success');
  }
}

// ============================================================
// PREVIEW & PDF
// ============================================================
function previewPeminjaman(id) {
  const record = dataPeminjaman.find(r => r.id === id);
  if (!record) return;

  currentPeminjamanId = id;
  const doc = document.getElementById('previewDoc');

  let peralatanRows = record.peralatan.map((p, i) =>
    `<tr><td style="text-align:center">${i+1}</td><td>${p.kode}</td><td>${p.nama}</td><td style="text-align:center">${p.qty}</td><td style="text-align:center">Unit</td><td>Baik</td></tr>`
  ).join('');

  let bahanRows = record.bahan.map((b, i) =>
    `<tr><td style="text-align:center">${record.peralatan.length + i + 1}</td><td>${b.kode}</td><td>${b.nama}</td><td style="text-align:center">${b.qty}</td><td style="text-align:center">${b.satuan}</td><td>-</td></tr>`
  ).join('');

  doc.innerHTML = `
    <div class="doc-header">
      <div class="doc-logo">
        <span style="color:#1a1a2e !important">🏛️</span>
      </div>
      <div class="doc-header-text">
        <p style="font-size:12px !important">KEMENTERIAN KETENAGAKERJAAN REPUBLIK INDONESIA</p>
        <h2>BALAI PELATIHAN VOKASI DAN PRODUKTIVITAS SORONG</h2>
        <h3>JURUSAN ELEKTRONIKA</h3>
        <p>Jl. Basuki Rahmat KM.7, Sorong, Papua Barat Daya</p>
      </div>
      <div class="doc-logo">
        <span style="color:#1a1a2e !important;font-size:16px !important;font-weight:700 !important">BPVP</span>
      </div>
    </div>

    <div class="doc-body">
      <div class="doc-title">FORMULIR PEMINJAMAN PERALATAN</div>
      <div class="doc-subtitle">DAN PENGGUNAAN BAHAN PELATIHAN</div>
      <div style="text-align:center;margin-bottom:20px">
        <span style="background:#f0f0ff;padding:4px 16px;border-radius:4px;font-size:13px;font-weight:700;border:1px solid #ddd">
          No: ${record.id}
        </span>
      </div>

      <div class="doc-info-grid">
        <div class="doc-info-row"><span class="label">Nama Peminjam</span><span class="value">: ${record.nama}</span></div>
        <div class="doc-info-row"><span class="label">No. Peserta</span><span class="value">: ${record.nomor}</span></div>
        <div class="doc-info-row"><span class="label">Program Pelatihan</span><span class="value">: ${record.program}</span></div>
        <div class="doc-info-row"><span class="label">Angkatan</span><span class="value">: ${record.angkatan}</span></div>
        <div class="doc-info-row"><span class="label">Tanggal Pinjam</span><span class="value">: ${formatDate(record.tglPinjam)}</span></div>
        <div class="doc-info-row"><span class="label">Tanggal Kembali</span><span class="value">: ${formatDate(record.tglKembali)}</span></div>
        <div class="doc-info-row"><span class="label">Instruktur PJ</span><span class="value">: ${record.instruktur}</span></div>
        <div class="doc-info-row"><span class="label">Lokasi Penggunaan</span><span class="value">: ${record.lokasi}</span></div>
      </div>

      <p style="font-size:12px;font-weight:700;margin:16px 0 8px">Keperluan: ${record.keperluan}</p>

      <table class="doc-table">
        <thead>
          <tr>
            <th style="width:40px">No</th>
            <th style="width:80px">Kode</th>
            <th>Nama Peralatan / Bahan</th>
            <th style="width:60px">Jml</th>
            <th style="width:60px">Satuan</th>
            <th style="width:80px">Kondisi</th>
          </tr>
        </thead>
        <tbody>
          ${peralatanRows}
          ${bahanRows}
          ${(!record.peralatan.length && !record.bahan.length) ?
            '<tr><td colspan="6" style="text-align:center">Tidak ada item</td></tr>' : ''}
        </tbody>
      </table>

      <div class="doc-notes">
        <h4>Ketentuan Peminjaman:</h4>
        <ol>
          <li>Peminjam bertanggung jawab penuh atas peralatan yang dipinjam.</li>
          <li>Peralatan harus dikembalikan dalam kondisi baik sesuai tanggal yang ditentukan.</li>
          <li>Kerusakan atau kehilangan menjadi tanggung jawab peminjam.</li>
          <li>Bahan habis pakai yang telah digunakan tidak perlu dikembalikan.</li>
          <li>Formulir ini berlaku sebagai bukti peminjaman yang sah.</li>
        </ol>
      </div>

      ${record.catatan !== '-' ? `<p style="font-size:12px;margin-top:12px"><strong>Catatan:</strong> ${record.catatan}</p>` : ''}

      <div class="doc-signatures">
        <div class="doc-sig-box">
          <p>Peminjam,</p>
          <div class="sig-line"></div>
          <p class="sig-name">${record.nama}</p>
          <p class="sig-nip">Peserta Pelatihan</p>
        </div>
        <div class="doc-sig-box">
          <p>Instruktur Penanggung Jawab,</p>
          <div class="sig-line"></div>
          <p class="sig-name">${record.instruktur}</p>
          <p class="sig-nip">Instruktur</p>
        </div>
        <div class="doc-sig-box">
          <p>Mengetahui,</p>
          <div class="sig-line"></div>
          <p class="sig-name">Ka. Sub. Bag. Tata Usaha</p>
          <p class="sig-nip">BPVP Sorong</p>
        </div>
      </div>
    </div>

    <div class="doc-footer">
      Dokumen ini dicetak secara digital oleh SIMPEL (Sistem Informasi Peminjaman Peralatan) BPVP Sorong
      <br>Dicetak pada: ${new Date().toLocaleDateString('id-ID', { weekday:'long', year:'numeric', month:'long', day:'numeric', hour:'2-digit', minute:'2-digit' })}
    </div>
  `;

  navigateTo('preview');
}

function downloadPDF() {
  const element = document.getElementById('previewDoc');
  const opt = {
    margin: [10, 10, 10, 10],
    filename: `Peminjaman_${currentPeminjamanId || 'BPVP'}_${new Date().toISOString().slice(0,10)}.pdf`,
    image: { type: 'jpeg', quality: 0.98 },
    html2canvas: { scale: 2, useCORS: true },
    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
  };

  showToast('Mengunduh PDF, harap tunggu...', 'info');
  html2pdf().set(opt).from(element).save().then(() => {
    showToast('PDF berhasil diunduh!', 'success');
  });
}

// ============================================================
// UTILITY FUNCTIONS
// ============================================================
function formatDate(dateStr) {
  if (!dateStr) return '-';
  const d = new Date(dateStr);
  return d.toLocaleDateString('id-ID', { day:'numeric', month:'long', year:'numeric' });
}

function setDefaultDates() {
  const today = new Date();
  const nextWeek = new Date(today);
  nextWeek.setDate(nextWeek.getDate() + 7);
  document.getElementById('pTanggalPinjam').value = today.toISOString().slice(0, 10);
  document.getElementById('pTanggalKembali').value = nextWeek.toISOString().slice(0, 10);
}

function updateBadges() {
  document.getElementById('badge-peralatan').textContent = dataPeralatan.length;
  document.getElementById('badge-bahan').textContent = dataBahan.length;
  document.getElementById('badge-riwayat').textContent = dataPeminjaman.length;

  // Update dashboard stat
  const statValues = document.querySelectorAll('.stat-value');
  if (statValues[5]) statValues[5].textContent = dataPeminjaman.filter(r =>
    r.createdAt && new Date(r.createdAt).toDateString() === new Date().toDateString()
  ).length;
}

function animateCounters() {
  document.querySelectorAll('.stat-value[data-count]').forEach(el => {
    const target = parseInt(el.dataset.count);
    let current = 0;
    const increment = target / 40;
    const timer = setInterval(() => {
      current += increment;
      if (current >= target) {
        current = target;
        clearInterval(timer);
      }
      el.textContent = Math.round(current);
    }, 30);
  });
}

function showToast(message, type = 'info') {
  const container = document.getElementById('toast-container');
  const icons = { success:'fa-check-circle', error:'fa-times-circle', warning:'fa-exclamation-triangle', info:'fa-info-circle' };
  const toast = document.createElement('div');
  toast.className = `toast ${type}`;
  toast.innerHTML = `<i class="fas ${icons[type]}"></i> ${message}`;
  container.appendChild(toast);
  setTimeout(() => {
    toast.style.opacity = '0';
    toast.style.transform = 'translateX(50px)';
    toast.style.transition = 'all 0.3s ease';
    setTimeout(() => toast.remove(), 300);
  }, 3500);
}

function addActivity(title, desc, dotColor) {
  const list = document.getElementById('activityList');
  const now = new Date();
  const timeStr = now.toLocaleTimeString('id-ID', { hour:'2-digit', minute:'2-digit' });
  const item = document.createElement('div');
  item.className = 'activity-item';
  item.innerHTML = `
    <div class="activity-dot ${dotColor}"></div>
    <div class="activity-info">
      <h5>${title}</h5>
      <p>${desc}</p>
    </div>
    <div class="activity-time">${timeStr}</div>
  `;
  list.insertBefore(item, list.firstChild);
}

// Close sidebar when clicking outside on mobile
document.addEventListener('click', (e) => {
  const sidebar = document.getElementById('sidebar');
  const toggle = document.querySelector('.menu-toggle');
  if (window.innerWidth <= 1024 && sidebar.classList.contains('open') &&
      !sidebar.contains(e.target) && !toggle.contains(e.target)) {
    sidebar.classList.remove('open');
  }
});
</script>
</body>
</html>
